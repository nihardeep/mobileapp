                    <div class="nav-item" id="navFlights" onclick="triggerHaptic('light', 'Flights tab clicked'); switchCategory(0); navigateTo('home')">
                        <div class="nav-icon">
                            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/></svg>
                        </div>
                        <span>Flights</span>
                        <div class="nav-indicator-dot"></div>
                    </div>
                    <div class="nav-item" id="navBot" onclick="triggerHaptic('medium', 'Chatbot support stand-by')">
                        <div class="nav-icon">
                            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                        </div>
                        <span>Hello 6E</span>
                        <div class="nav-indicator-dot"></div>
                    </div>
                    <div class="nav-item" id="navTrips" onclick="navigateTo('trips')">
                        <div class="nav-icon">
                            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="16" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="4"/><line x1="8" y1="2" x2="8" y2="4"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </div>
                        <span>My Trips</span>
                        <div class="nav-indicator-dot"></div>
                    </div>
                    <div class="nav-item" id="navPick" onclick="triggerHaptic('light', '6EPick tab clicked')">
                        <div class="nav-icon">
                            <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                        </div>
                        <span>6EPick</span>
                        <div class="nav-indicator-dot"></div>
                    </div>
                </div>

                <!-- Backdrop for drawers -->
                <div class="bottom-sheet-backdrop" id="bottomSheetBackdrop" onclick="closeAllDrawers()"></div>

                <!-- Airport Selection Sheet -->
                <div class="bottom-sheet-drawer" id="bottomSheetDrawer">
                    <div class="drawer-header">
                        <div class="drawer-title" id="drawerTitle">Select Airport</div>
                        <div class="drawer-close" onclick="closeAllDrawers()">✕</div>
                    </div>
                    <input type="text" class="drawer-search-bar" placeholder="Search city or airport..." id="airportSearchInput" oninput="filterAirports()">
                    
                    <div class="airport-options-list" id="airportList">
                        <!-- Filled by JS -->
                    </div>
                </div>

                <!-- Date Selection Sheet (Calendar) -->
                <div class="bottom-sheet-drawer" id="dateSheetDrawer">
                    <div class="drawer-header">
                        <div class="drawer-title">Select Date</div>
                        <div class="drawer-close" onclick="closeAllDrawers()">✕</div>
                    </div>
                    <div class="calendar-month-header">
                        <div class="calendar-month-prev" onclick="changeMonth(-1)">◄</div>
                        <div class="calendar-month-title" id="calendarMonthTitle">June 2026</div>
                        <div class="calendar-month-next" onclick="changeMonth(1)">►</div>
                    </div>
                    <div class="calendar-weekdays">
                        <span>Su</span><span>Mo</span><span>Tu</span><span>We</span><span>Th</span><span>Fr</span><span>Sa</span>
                    </div>
                    <div class="calendar-grid" id="calendarGrid">
                        <!-- Filled dynamically by JS -->
                    </div>
                </div>

                <!-- Travelers Selection Sheet (Steppers) -->
                <div class="bottom-sheet-drawer" id="travelersSheetDrawer">
                    <div class="drawer-header">
                        <div class="drawer-title">Select Travelers</div>
                        <div class="drawer-close" onclick="closeAllDrawers()">✕</div>
                    </div>
                    <div class="travelers-options-list">
                        <!-- Adults -->
                        <div class="traveler-row">
                            <div class="traveler-info">
                                <span class="traveler-type">Adults</span>
                                <span class="traveler-desc">12+ years</span>
                            </div>
                            <div class="stepper-controls">
                                <button class="stepper-btn" onclick="adjustTravelers('adults', -1)">-</button>
                                <span class="stepper-value" id="countAdults">1</span>
                                <button class="stepper-btn" onclick="adjustTravelers('adults', 1)">+</button>
                            </div>
                        </div>
                        <!-- Children -->
                        <div class="traveler-row">
                            <div class="traveler-info">
                                <span class="traveler-type">Children</span>
                                <span class="traveler-desc">2-12 years</span>
                            </div>
                            <div class="stepper-controls">
                                <button class="stepper-btn" onclick="adjustTravelers('children', -1)">-</button>
                                <span class="stepper-value" id="countChildren">0</span>
                                <button class="stepper-btn" onclick="adjustTravelers('children', 1)">+</button>
                            </div>
                        </div>
                        <!-- Infants -->
                        <div class="traveler-row">
                            <div class="traveler-info">
                                <span class="traveler-type">Infants</span>
                                <span class="traveler-desc">Under 2 years</span>
                            </div>
                            <div class="stepper-controls">
                                <button class="stepper-btn" onclick="adjustTravelers('infants', -1)">-</button>
                                <span class="stepper-value" id="countInfants">0</span>
                                <button class="stepper-btn" onclick="adjustTravelers('infants', 1)">+</button>
                            </div>
                        </div>
                    </div>
                    <button class="confirm-travelers-btn" onclick="confirmTravelers()">Confirm</button>
                </div>

            </div>
        </div>

    </div>

    <!-- Haptic audio simulation nodes -->
    <audio id="sndTap" src="https://assets.mixkit.co/active_storage/sfx/2568/2568-84.wav" preload="auto"></audio>
    <audio id="sndConfirm" src="https://assets.mixkit.co/active_storage/sfx/2019/2019-84.wav" preload="auto"></audio>
    <audio id="sndAlert" src="https://assets.mixkit.co/active_storage/sfx/911/911-84.wav" preload="auto"></audio>

    <script src="app.js"></script>
</body>
</html>
