
                <!-- Plane Flyover Transition -->
                
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IndiGo Premium Mobile Prototype</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <div class="prototype-container">
        
        <!-- ==========================================================================
             DEVELOPER SIMULATOR COCKPIT (Left Sidebar Xcode Theme)
             ========================================================================== -->
        <div class="dev-simulator-console">
            <div class="dev-console-title">
                <span>⚡</span> IndiGo Flight Deck Cockpit
            </div>
            <p class="dev-console-desc">
                Simulate flight lifecycle states, trigger Siri-style voice inputs, adjust atmospheric parallax physics, and monitor real-time haptic oscilloscope waveforms.
            </p>
            
            <div class="dev-state-group">
                <div class="dev-state-label">Screen Navigation</div>
                <div class="dev-btn-stack">
                    <button class="dev-trigger-btn active" onclick="navigateTo('home')">
                        Home Page
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="devNavDeals" onclick="navigateTo('deals')">
                        Offers & Deals
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="devNavTrips" onclick="triggerHomepageCompanion()">
                        My Trips (Companion)
                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 2 11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateStudentPersona" onclick="toggleStudentPersona()">
                        🎓 Student Persona
                        <div class="dev-btn-indicator"></div>
                    </button>
                </div>
            </div>

            <div class="dev-state-group">
                <div class="dev-state-label">Flight Lifecycle States</div>
                <div class="dev-btn-stack grid-btn-stack">
                    <button class="dev-trigger-btn active" id="btnStateCheckinOpen" onclick="setFlightState('checkin_open')">
                        1. Check-in Open
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateCheckedIn" onclick="setFlightState('checked_in')">
                        2. Checked In
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateGateOpen" onclick="setFlightState('gate_open')">
                        3. Gate Open
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateAirportCheckin" onclick="setFlightState('airport_checkin')">
                        4. Desk Closed
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateGoToCounter" onclick="setFlightState('go_to_counter')">
                        5. Visit Counter
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateGateUpdate" onclick="setFlightState('gate_update')">
                        6. Gate Update
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateDelayed" onclick="setFlightState('delayed')">
                        7. Delay Alert
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateCancelled" onclick="setFlightState('cancelled')">
                        8. Cancel Alert
                        <div class="dev-btn-indicator"></div>
                    </button>
                    <button class="dev-trigger-btn" id="btnStateStudentPersona" onclick="toggleStudentPersona()">
                        🎓 Student Persona
                        <div class="dev-btn-indicator"></div>
                    </button>
                </div>
            </div>

            <div class="dev-state-group">
                <div class="dev-state-label">Atmosphere & Sound overrides</div>
                <div class="dev-slider-control">
                    <div class="slider-lbl-row">
                        <span>Parallax Drift</span>
                        <span id="lblCloudSpeed">20s</span>
                    </div>
                    <input type="range" id="cloudSpeedRange" min="5" max="45" value="20" class="cockpit-range" oninput="changeCloudSpeed(this.value)">
                </div>
                <div class="dev-slider-control">
                    <div class="slider-lbl-row">
                        <span>Haptic Volume</span>
                        <span id="lblHapticVol">80%</span>
                    </div>
                    <input type="range" id="hapticVolumeRange" min="0" max="100" value="80" class="cockpit-range" oninput="changeHapticVolume(this.value)">
                    <button class="dev-trigger-btn" id="btnStateStudentPersona" onclick="toggleStudentPersona()">
                        🎓 Student Persona
                        <div class="dev-btn-indicator"></div>
                    </button>
                </div>
            </div>

            <div class="dev-state-group">
                <div class="dev-state-label">Haptic Oscilloscope Waveform</div>
                <div class="interactive-feedback-indicator" id="hapticFeedbackLog">
                    <div class="feedback-status-dot" id="hapticDot"></div>
                    <span id="hapticMessage">Device standing by...</span>
                </div>
                <div class="waveform-container" style="margin-top: 8px;">
                    <canvas id="hapticWaveformCanvas" width="230" height="50"></canvas>
                </div>
            </div>
        </div>

        <!-- ==========================================================================
             HIGH-FIDELITY iPHONE 16 PRO FRAME (Right Panel)
             ========================================================================== -->
        <div class="iphone-frame">
            <div class="iphone-screen">
                
                <!-- Parallax Atmospheric Background -->
                <div class="sky-clouds-container">
                    <div class="cloud-layer cloud-slow"></div>
                    <div class="cloud-layer cloud-medium"></div>
                    <div class="cloud-layer cloud-fast"></div>
                    <div class="sky-light-rays"></div>
                </div>

                <!-- Siri Voice Input Listening Overlay -->
                <div class="siri-voice-overlay" id="siriVoiceOverlay" onclick="closeVoiceSearch()">
                    <div class="siri-backdrop-blur"></div>
                    <div class="siri-overlay-content">
                        <div class="siri-listening-text">Listening for destination...</div>
                        <div class="siri-canvas-container">
                            <canvas id="siriVoiceCanvas" width="280" height="100"></canvas>
                        </div>
                        <div class="siri-hint-text">Tap anywhere to dismiss</div>
                    </div>
                </div>

                <!-- Plane Takeoff Screen Transition Overlay -->
                <div class="plane-transition-overlay" id="planeTransitionOverlay">
                    <div class="plane-transition-bg"></div>
                    <div class="plane-transition-aircraft" id="transitionAircraft">
                        <svg viewBox="0 0 24 24" width="80" height="80" fill="currentColor">
                            <path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/>
                        </svg>
                        <div class="plane-transition-vapor"></div>
                    </div>
                </div>

                <!-- Cockpit Interstitial Overlay -->
                <div class="cockpit-interstitial" id="cockpitInterstitial">
                    <div class="cockpit-3d-render"></div>
                    <div class="cockpit-content">
                        <div class="cockpit-logo-pulse">
                            <span style="font-weight: 900; font-style: italic; font-size: 28px; color: #fff; letter-spacing: -0.5px; text-shadow: 0 2px 10px rgba(0,0,0,0.5);">go<span style="color: #ffd15c;">IndiGo</span></span>
                        </div>
                        <div class="cockpit-tagline-container">
                            <div class="cockpit-tagline" id="cockpitTagline" style="text-shadow: 0 1px 4px rgba(0,0,0,0.8);">Hold tight, we're about to fly...</div>
                        </div>
                    </div>
                </div>

                <!-- Expandable iOS Dynamic Island -->
                <div class="dynamic-island-container">
                    <div class="dynamic-island" id="dynamicIsland" onclick="toggleIslandExpansion()">
                        <div class="dynamic-island-content" id="islandContent">
                            <svg class="island-icon-svg" viewBox="0 0 24 24" width="12" height="12" fill="currentColor"><path d="M12 2L15 9L22 12L15 15L12 22L9 15L2 12L9 9Z"/></svg>
                            <div class="island-text" id="islandText">
                                <strong id="islandHeadline">Indigo 6E 2015</strong>
                                <span id="islandSubline">Welcome Aboard</span>
                            </div>
                            <div class="island-action-badge" id="islandBadge">Boarding</div>
                        </div>
                    </div>
                </div>

                <!-- Native iOS Status Bar -->
                <div class="status-bar">
                    <div class="status-time" id="statusTime">09:41</div>
                    <div class="status-icons">
                        <svg class="status-svg" viewBox="0 0 100 100" width="13" height="13" fill="currentColor"><path d="M10 80h10v10H10zm20-20h10v30H30zm20-20h10v50H50zm20-20h10v70H70zm20-20h10v90H90z"/></svg>
                        <svg class="status-svg" viewBox="0 0 24 24" width="13" height="13" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0M1.42 9a16 16 0 0 1 21.16 0M8.53 16.11a6 6 0 0 1 6.94 0M12 20h.01"/></svg>
                        <svg class="status-svg" viewBox="0 0 24 24" width="15" height="15" stroke="currentColor" fill="none" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="16" height="10" rx="2" ry="2"/><line x1="22" y1="11" x2="22" y2="13"/></svg>
                    </div>
                </div>

                <!-- Main Scrollable App Container -->
                <div class="app-content" id="appContent">
                    
                    <!-- ==========================================================
                         SCREEN 1: HOME PAGE
                         ========================================================== -->
                    <div class="screen active" id="screenHome">
                        <div class="screen-home-content" id="homeContentContainer">
                            
                            <!-- Header with Profile -->
                            <div class="home-header" id="homeHeaderSection">
                                <div class="greeting-container">
                                    <div class="greeting-name" id="userGreeting">Hi Nihar!</div>
                                </div>
                                <div class="header-actions">
                                    <div class="header-logo-circle" onclick="triggerHaptic('light', 'Logo clicked')">
                                        <svg viewBox="0 0 24 24" class="header-logo-badge-svg" width="16" height="16" fill="currentColor"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L13 19v-5.5l8 2.5z"/></svg>
                                    </div>
                                    <div class="header-avatar-circle" onclick="triggerHaptic('light', 'Profile clicked'); toggleLoyaltyState();">
                                        <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                                    </div>
                                </div>
                            </div>

                            <!-- Category Tabs -->
                            <div class="category-tabs-container" id="categoryTabsSection">
                                <div class="category-tab active" onclick="switchCategory(0)">Flights</div>
                                <div class="category-tab" onclick="switchCategory(1)">Hotels</div>
                                <div class="category-tab" onclick="switchCategory(2)">Cabs</div>
                                <div class="category-tab" onclick="switchCategory(3)">Deals</div>
                                <div class="category-tab" onclick="switchCategory(4)">More</div>
                            </div>

                            <!-- Frosted Glass Search Widget -->
                            <div class="search-widget-panel" id="searchWidgetSection" style="padding-bottom: 24px;">
    


    <div id="manualSearchView" class="search-view-container active-view" style="display: block;">
        



                                <div class="route-row">
                                    <div class="input-group" id="inputGroupFrom" onclick="openAirportSelector('from')">
                                        <div class="input-label">From</div>
                                        <div class="input-value" id="valFromCode">Select City</div>
                                    </div>
                                    
                                    <div class="swap-route-btn" onclick="swapRoutes()">
                                        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7 16-4-4 4-4M3 12h18M17 8l4 4-4 4"/></svg>
                                    </div>

                                    <div class="input-group" id="inputGroupTo" onclick="openAirportSelector('to')">
                                        <div class="input-label">Where to?</div>
                                        <div class="input-value" id="valToCode">Select City</div>
                                        
                                    </div>
                                </div>

                                
<div class="search-accordion-toggle" onclick="toggleSearchWidget()" id="searchAccordionToggle" style="display: none;">
    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
</div>

<div class="search-widget-expanded-content" id="searchWidgetExpandedContent">
<div class="search-details-row" style="margin-top: 8px; display: flex; gap: 8px;">
                                    <div class="input-group" id="inputGroupDate" onclick="openDatePicker()" style="flex: 1;">
                                        <div class="input-label">Departure</div>
                                        <div class="input-value" id="valDateText">Select Date</div>
                                    </div>
                                    <div class="input-group" id="inputGroupTravelers" onclick="openTravelersPicker()" style="flex: 1;">
                                        <div class="input-label">Travelers</div>
                                        <div class="input-value" id="valTravelersText">1 Traveler</div>
                                    </div>
                                </div>
                                
                                
        <div class="unified-nlp-container" style="margin-top: 16px; margin-bottom: 16px;">
            <div class="nlp-input-wrapper" style="background: #fff; border-radius: 32px; padding: 8px 8px 8px 16px; position: relative; box-shadow: 0 4px 20px rgba(0,31,84,0.08); border: none; display: flex; align-items: center; margin-bottom: 16px;">
            
            
            
            <div id="nlpBackIcon" onclick="exitNlpMode(event)" style="color: var(--indigo-blue); margin-right: 12px; cursor: pointer; display: none; align-items: center; justify-content: center; width: 32px; height: 32px; background: rgba(0,95,169,0.05); border-radius: 50%;">
                <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
            </div>
    <div id="customNlpPlaceholder" style="position: absolute; left: 16px; top: 50%; transform: translateY(-50%); pointer-events: none; color: var(--text-secondary); font-size: 14px; font-weight: 500; display: flex; align-items: center;">
                Ask 6eSkai about &nbsp;<span id="nlpAnimatedText" style="color: var(--indigo-navy); font-weight: 600; transition: opacity 0.3s ease;">'Coorg Homestays'</span>
            </div>
    
<input type="text" id="nlpSearchInput" class="nlp-placeholder" placeholder="" style="position: relative; z-index: 2; flex: 1; color: var(--indigo-navy); font-size: 14px; font-weight: 500; border: none; background: transparent; outline: none; width: 100%;">
<div class="nlp-mic-icon" onclick="startVoiceSearch(event)" style="background: #fff; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 0 0 1px rgba(0,95,169,0.2), 0 0 0 3px rgba(0,95,169,0.05); color: var(--indigo-blue); cursor: pointer; transition: all 0.3s ease;">
                <svg viewBox="0 0 24 24" width="14" height="14" stroke="currentColor" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/>
                    <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                    <line x1="12" y1="19" x2="12" y2="22"/>
                </svg>
            </div>
        </div>
        
        <div class="trending-prompts-section" id="trendingPromptsSection" style="display: none; background: #fafcff; border-radius: 24px; padding: 24px; box-shadow: 0 8px 30px rgba(0,31,84,0.06); border: 1px solid #eef2f6; animation: slideDown 0.3s ease;">
            <div class="trending-prompts-title" style="font-size: 13px; font-weight: 800; color: #5a6b82; letter-spacing: 0.5px; margin-bottom: 20px; text-transform: uppercase;">TRENDING PROMPTS</div>
            
            <div class="trending-prompt-card" onclick="simulateIntent('Cheapest flights to Goa', 'GOI')" style="display: flex; align-items: center; gap: 16px; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.03); cursor: pointer;">
                <div class="tpc-icon" style="width: 56px; height: 56px; background: #e8f4fc; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; box-shadow: inset 0 2px 4px rgba(255,255,255,0.5);">✈️</div>
                <div class="tpc-content" style="flex: 1;">
                    <div class="tpc-tag" style="display: inline-flex; align-items: center; gap: 4px; color: var(--indigo-blue); border: 1px solid rgba(0,95,169,0.2); font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 6px; margin-bottom: 6px; text-transform: uppercase;"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L14 19v-5.5l8 2.5z"/></svg> FLIGHTS</div>
                    <div class="tpc-text" style="font-size: 15px; font-weight: 500; color: var(--indigo-navy); line-height: 1.3;">Cheapest flights to Goa</div>
                </div>
            </div>

            <div class="trending-prompt-card" onclick="simulateIntent('Flights to Beach destinations', 'GOI')" style="display: flex; align-items: center; gap: 16px; padding: 12px 0; border-bottom: 1px solid rgba(0,0,0,0.03); cursor: pointer;">
                <div class="tpc-icon" style="width: 56px; height: 56px; background: #e0f7fa; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; box-shadow: inset 0 2px 4px rgba(255,255,255,0.5);">🏖️</div>
                <div class="tpc-content" style="flex: 1;">
                    <div class="tpc-tag" style="display: inline-flex; align-items: center; gap: 4px; color: var(--indigo-blue); border: 1px solid rgba(0,95,169,0.2); font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 6px; margin-bottom: 6px; text-transform: uppercase;"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L14 19v-5.5l8 2.5z"/></svg> FLIGHTS</div>
                    <div class="tpc-text" style="font-size: 15px; font-weight: 500; color: var(--indigo-navy); line-height: 1.3;">Flights to Beach destinations</div>
                </div>
            </div>

            <div class="trending-prompt-card" onclick="simulateIntent('Flight to Europe', 'CDG')" style="display: flex; align-items: center; gap: 16px; padding: 12px 0; cursor: pointer;">
                <div class="tpc-icon" style="width: 56px; height: 56px; background: #f3e5f5; border-radius: 16px; display: flex; align-items: center; justify-content: center; font-size: 28px; flex-shrink: 0; box-shadow: inset 0 2px 4px rgba(255,255,255,0.5);">🌍</div>
                <div class="tpc-content" style="flex: 1;">
                    <div class="tpc-tag" style="display: inline-flex; align-items: center; gap: 4px; color: var(--indigo-blue); border: 1px solid rgba(0,95,169,0.2); font-size: 10px; font-weight: 700; padding: 4px 8px; border-radius: 6px; margin-bottom: 6px; text-transform: uppercase;"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L14 19v-5.5l8 2.5z"/></svg> FLIGHTS</div>
                    <div class="tpc-text" style="font-size: 15px; font-weight: 500; color: var(--indigo-navy); line-height: 1.3;">Flight to Europe</div>
                </div>
            </div>
        </div>
        </div>
        <div class="search-btn-container" id="searchBtnContainer">
    
                                    <button class="riyadh-search-btn" id="searchFlightsBtn" onclick="searchFlights()">
                                        Search Flights ➔
                                    </button>
                                </div>
</div>

    </div>

    <!-- AI NLP Search View (Hidden) -->
    
    
</div>
<!-- STUDENT HYPER-PERSONALIZED BANNER -->
                            <div class="student-hyper-banner-wrapper" id="studentBannerWrapper">
                                <div class="student-hyper-banner" onclick="openStudentHub()">
                                    <div class="shb-icon">🎓</div>
                                    <div class="shb-content">
                                        <div class="shb-title">Welcome back, Student!</div>
                                        <div class="shb-desc">10% Off • Free Date Change • +15Kg Extra Baggage</div>
                                    </div>
                                    <div class="shb-cta">Search ➔</div>
                                </div>
                            </div>

                            <!-- Recent Searches -->
                            

<div id="tripCompanionPlaceholder" style="order: 3; height: 0; overflow: hidden; position: relative; transition: height 0.4s ease; margin-bottom: 0;">
    <svg id="inlinePlaneIcon" viewBox="0 0 24 24" width="32" height="32" fill="var(--indigo-blue)" style="position: absolute; top: 50%; left: -50px; transform: translateY(-50%) rotate(90deg); transition: left 1s cubic-bezier(0.4, 0, 0.2, 1);">
        <path d="M21 16v-2l-8-5V3.5c0-.83-.67-1.5-1.5-1.5S10 2.67 10 3.5V9l-8 5v2l8-2.5V19l-2 1.5V22l3.5-1 3.5 1v-1.5L14 19v-5.5l8 2.5z"/>
    </svg>
</div>
<div class="flight-state-wrapper" id="homeFlightStateWrapper" style="order: 3; display: none;">
                            
                                                                                    <!-- Upfront Upgrade Suggestions Section -->
                                                        <div class="upgrade-promo-card subtle-glass" id="upgradePromoCard" style="flex-direction: column; align-items: flex-start; height: auto;">
                                <div style="font-size: 11px; font-weight: 800; color: #60a5fa; margin-bottom: 6px; letter-spacing: 0.5px; text-transform: uppercase;">IndiGo Upfront</div>
                                <div style="display: flex; width: 100%; align-items: center; justify-content: space-between;">
                                    <div class="animated-text-container">
                                        <div class="animated-benefit-frame frame-1">
                                            <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" style="margin-right: 8px; color: #60a5fa;">
